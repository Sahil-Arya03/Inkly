# Inkly backend — required environment variables.
# Copy to .env (gitignored) for reference, but note Spring Boot does NOT read
# .env files: export these in your shell / IDE run config / deployment env.
# The app fails fast at startup if any of these is missing.

# Neon Postgres password for spring.datasource.password
DB_PASSWORD=change-me

# JWT signing secret (HS256). Must be at least 32 bytes. Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-bytes

# Google OAuth client secret from Google Cloud Console (calendar sync)
GOOGLE_OAUTH_CLIENT_SECRET=change-me

# AES-256 key for encrypting stored Google refresh tokens.
# Must base64-decode to exactly 32 bytes. Generate: openssl rand -base64 32
CALENDAR_TOKEN_ENCRYPTION_KEY=change-me-base64-32-bytes

